# Database - Railway auto-injects this; for local dev, point to your local Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rapid_response?sslmode=disable"

# Better Auth - generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Resend (Phase 2)
RESEND_API_KEY=""

# reCAPTCHA v3 - get keys at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# Optional: custom map tiles
NEXT_PUBLIC_MAP_TILE=""
